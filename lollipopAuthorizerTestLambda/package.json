{
  "name": "lollipop-backend-logger",
  "version": "1.0.0",
  "description": "Test lambda to validate LollipopAuthorizer - emulates a backend endpoint that receives authorized requests",
  "main": "index.js",
  "scripts": {
    "test": "nyc --reporter=html --reporter=text mocha './src/test/**/*.test.js' --recursive --timeout=3000 --exit",
    "coverage": "nyc report --reporter=lcov",
    "test-build": "npm run-script test && npm run-script coverage && npm run-script build",
    "build": "npm prune --production && rm -f ./function.zip && zip -r ./function.zip . -x './src/test/*' -x '*.md' -x '*.env' -x '*.gitignore' -x 'coverage/*' -x '.nyc_output/*'"
  },
  "keywords": [
    "lollipop",
    "authorizer",
    "test",
    "pagopa",
    "lambda",
    "aws"
  ],
  "author": "PagoPA Team",
  "license": "ISC",
  "dependencies": {
    "aws-xray-sdk-core": "^3.3.6"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "mocha": "^9.2.2",
    "nyc": "^15.1.0",
    "lambda-tester": "^4.0.1",
    "sonarqube-scanner": "^3.3.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "mocha": {
      "minimatch": "4.2.6",
      "glob": {
        "minimatch": "3.1.5"
      }
    },
    "test-exclude": {
      "minimatch": "3.1.5"
    }
  }
}