{
  "name": "token-exchange-v2",
  "version": "1.0.0",
  "description": "Lambda function to handle token exchange with One Identity provider.",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "npm run type-check && esbuild src/app/index.ts --bundle --platform=node --outdir=dist --minify --sourcemap && cd dist && zip -r ../function.zip .",
    "test": "npm run type-check && jest --coverage --silent",
    "test-build": "npm run test && npm run coverage && npm run sonar && npm run build",
    "coverage": "jest --coverage --coverageReporters=lcov",
    "sonar": "node sonarqube-scanner.js -Dsonar.login=${SONAR_TOKEN}",
    "clean": "rm -rf dist function.zip coverage"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-kms": "^3.948.0",
    "aws-xray-sdk-core": "^3.12.0",
    "base64url": "^3.0.1",
    "bunyan": "^1.8.15",
    "jsonwebtoken": "^9.0.0",
    "jwk-to-pem": "^2.0.7"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@types/bunyan": "^1.8.11",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jwk-to-pem": "^2.0.3",
    "esbuild": "^0.27.1",
    "jest": "^30.2.0",
    "nyc": "^17.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "18.x"
  }
}
